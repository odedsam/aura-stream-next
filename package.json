{
  "packageManager": "pnpm@10.10.0",
  "name": "aura-stream",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "clean": "rimraf node_modules .next pnpm-lock.yaml",
    "dev": "next dev --turbopack",
    "generate": "prisma generate",
    "build": "pnpm run generate && next build --webpack",
    "start": "next start",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.9.0",
    "@supabase/supabase-js": "^2.49.10",
    "@tanstack/react-query": "^5.77.2",
    "@tanstack/react-query-devtools": "^5.77.2",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "16.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.57.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.3.0",
    "zod": "^3.25.49",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.3",
    "prettier": "3.5.3",
    "prisma": "^6.9.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "ts-prune": "^0.10.3",
    "tsx": "^4.19.4",
    "typescript": "5.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,scss,sass,less,md,mdx,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
